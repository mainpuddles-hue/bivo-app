{
  "expo": {
    "name": "Bivo",
    "slug": "bivo-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "bivo",
    "owner": "puddles",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "io.bivoapp.app",
      "buildNumber": "1",
      "usesAppleSignIn": true,
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSCameraUsageDescription": "Bivo needs camera access to take photos for posts.",
        "NSPhotoLibraryUsageDescription": "Bivo needs photo library access to add images to posts.",
        "NSPhotoLibraryAddUsageDescription": "Bivo saves photos to your gallery.",
        "NSLocationWhenInUseUsageDescription": "Bivo shows nearby posts and places on the map."
      },
      "associatedDomains": [
        "applinks:bivoapp.io"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0A",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "io.bivoapp.app",
      "versionCode": 1,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "bivoapp.io",
              "pathPrefix": "/post"
            },
            {
              "scheme": "https",
              "host": "bivoapp.io",
              "pathPrefix": "/events"
            },
            {
              "scheme": "https",
              "host": "bivoapp.io",
              "pathPrefix": "/messages"
            },
            {
              "scheme": "https",
              "host": "bivoapp.io",
              "pathPrefix": "/profile"
            },
            {
              "scheme": "https",
              "host": "bivoapp.io",
              "pathPrefix": "/search"
            },
            {
              "scheme": "https",
              "host": "bivoapp.io",
              "pathPrefix": "/settings"
            },
            {
              "scheme": "https",
              "host": "bivoapp.io",
              "pathPrefix": "/bookings"
            },
            {
              "scheme": "https",
              "host": "bivoapp.io",
              "pathPrefix": "/invite"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-dev-client",
        {
          "launchMode": "most-recent"
        }
      ],
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Bivo shows nearby posts and places on the map."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/android-icon-monochrome.png",
          "color": "#0A0A0A"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Bivo needs photo library access to add images to posts.",
          "cameraPermission": "Bivo needs camera access to take photos for posts."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Bivo needs camera access to take photos for posts."
        }
      ],
      "expo-web-browser",
      "@react-native-google-signin/google-signin"

    ],
    "extra": {
      "eas": {
        "projectId": "504a9107-9e8e-4e5d-90fe-ea7564166e33"
      },
      "privacyPolicyUrl": "https://bivoapp.io/privacy",
      "termsOfServiceUrl": "https://bivoapp.io/terms",
      "supportEmail": "tuki@bivoapp.io",
      "router": {}
    },
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/504a9107-9e8e-4e5d-90fe-ea7564166e33",
      "fallbackToCacheTimeout": 0
    },
    "newArchEnabled": true
  }
}
